{
	"name": "@whitespace/pi-minimal-toolcall",
	"version": "0.2.1",
	"description": "Calm tool-call rendering for Pi: one row per group of consecutive tool calls, multi-tool groups joined with `&`, relative paths, syntax-highlighted write expand, full per-package config.",
	"type": "module",
	"license": "MIT",
	"files": [
		"index.ts",
		"src",
		"!src/**/*.test.ts",
		"!src/**/*.test.*.ts",
		"config",
		"demo.mp4",
		"ss_1.png",
		"ss_2.png",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"check": "npm run typecheck && npm run test",
		"prepack": "npm run check",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test tests/*.test.ts src/**/*.test.ts",
		"pack:dry": "npm pack --dry-run"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "^0.79.0",
		"@earendil-works/pi-coding-agent": "^0.79.0",
		"@earendil-works/pi-tui": "^0.79.0",
		"@types/node": "^24.10.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.0"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"video": "https://github.com/fahmiirsyadk/pi-minimal-toolcall/raw/main/demo.mp4",
		"image": "https://github.com/fahmiirsyadk/pi-minimal-toolcall/raw/main/ss_1.png"
	},
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"tui",
		"minimal",
		"tool-call",
		"compact",
		"configurable"
	],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fahmiirsyadk/pi-minimal-toolcall.git"
	},
	"homepage": "https://github.com/fahmiirsyadk/pi-minimal-toolcall#readme",
	"bugs": {
		"url": "https://github.com/fahmiirsyadk/pi-minimal-toolcall/issues"
	},
	"engines": {
		"node": ">=20.6.0"
	},
	"main": "index.ts",
	"exports": "./index.ts"
}
